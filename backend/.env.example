# Backend runtime
PORT=3000

# JWT signing secret for auth tokens
JWT_SECRET=replace_with_secure_random_secret
JWT_EXPIRES_IN=12h

# Cohere API key for AI ingredient extraction endpoint
COHERE_API_KEY=replace_with_cohere_api_key

# PostgreSQL connection string (Supabase Postgres or any Postgres)
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Force IPv4 socket for Postgres DNS results (recommended on platforms without IPv6 egress)
PG_FORCE_IPV4=true

# Optional: direct Postgres host IP override if DNS resolution is unstable
# PGHOSTADDR=1.2.3.4
